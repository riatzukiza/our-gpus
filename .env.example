APP_ENV=dev
DATABASE_URL=sqlite:///./data/ollama.db
REDIS_URL=redis://redis:6379/0
ADMIN_API_KEY=
OUR_GPUS_API_KEY=
PROXX_API_KEY=
POSTGRES_USER=our_gpus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=our_gpus
API_DATABASE_URL=postgresql+psycopg://our_gpus:change-me@127.0.0.1:5432/our_gpus
WORKER_DATABASE_URL=postgresql+psycopg://our_gpus:change-me@postgres:5432/our_gpus
PROBE_TIMEOUT_SECS=5
PROBE_CONCURRENCY=200
PROBE_RETRIES=2
PROBE_BATCH_SIZE=100
GEOCODE_TIMEOUT_SECS=5
GEOCODE_RETRIES=2
GEOCODE_DATA_PATH=/app/data/geoip2fast-city.dat.gz
GEOCODE_DATA_URL=https://github.com/rabuchaim/geoip2fast/releases/download/LATEST/geoip2fast-city.dat.gz
UPLOAD_MAX_MB=4096
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
BATCH_SIZE=1000
WORKERS=4
