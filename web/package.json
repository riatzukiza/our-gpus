{
  "name": "our-gpus-web",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.1.29",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx tsc && bunx vite build",
    "preview": "bunx vite preview",
    "lint": "bunx eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "bunx prettier --write src/**/*.{ts,tsx,css}"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "axios": "^1.7.2",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.24.1",
    "lucide-react": "^0.395.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "prettier": "^3.3.2"
  }
}